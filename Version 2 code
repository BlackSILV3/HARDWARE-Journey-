<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VLSI & Embedded Systems — Master Roadmap</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

  :root {
    --ink: #0a0e1a;
    --ink2: #141929;
    --surface: #f4f1eb;
    --accent: #e8440a;
    --gold: #c9860a;
    --teal: #0a7a6e;
    --blue: #1a3a8f;
    --muted: #6b7280;
    --border: #d4cfc5;
    --stage-colors: #e8440a, #c9860a, #0a7a6e, #1a3a8f, #7c3aed, #be185d, #065f46, #92400e, #1e3a5f, #4a1942;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--surface);
    color: var(--ink);
    line-height: 1.6;
  }

  /* ── COVER ── */
  .cover {
    background: var(--ink);
    color: var(--surface);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 60px 40px;
    position: relative;
    overflow: hidden;
  }

  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 39px,
      rgba(255,255,255,0.03) 39px, rgba(255,255,255,0.03) 40px
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 39px,
      rgba(255,255,255,0.03) 39px, rgba(255,255,255,0.03) 40px
    );
  }

  .cover-chip {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 24px;
    position: relative;
  }

  .cover h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 800;
    line-height: 1.05;
    position: relative;
    margin-bottom: 8px;
  }

  .cover h1 span { color: var(--accent); }

  .cover-sub {
    font-family: 'Syne', sans-serif;
    font-size: clamp(18px, 3vw, 28px);
    font-weight: 400;
    color: #8899cc;
    margin-bottom: 40px;
    position: relative;
  }

  .cover-stats {
    display: flex;
    gap: 48px;
    position: relative;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 48px;
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: var(--accent);
    display: block;
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #8899cc;
    margin-top: 4px;
  }

  .cover-divider {
    width: 80px;
    height: 2px;
    background: var(--accent);
    margin: 0 auto 40px;
    position: relative;
  }

  .cover-meta {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: #4a5568;
    position: relative;
    letter-spacing: 1px;
  }

  /* ── SECTION HEADERS ── */
  .section-header {
    background: var(--ink2);
    color: var(--surface);
    padding: 48px 60px;
    margin-top: 0;
  }

  .section-header h2 {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-header h3 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
  }

  /* ── INTRO OVERVIEW ── */
  .intro {
    padding: 64px 60px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }

  .intro-card {
    border: 1.5px solid var(--border);
    padding: 28px;
    position: relative;
  }

  .intro-card-icon {
    font-size: 28px;
    margin-bottom: 12px;
    display: block;
  }

  .intro-card h4 {
    font-family: 'Syne', sans-serif;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .intro-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
  }

  .intro-card .tag {
    position: absolute;
    top: -1px;
    right: 24px;
    background: var(--accent);
    color: white;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    padding: 3px 10px;
    letter-spacing: 1px;
  }

  /* ── FLOW DIAGRAM ── */
  .flow-section {
    background: var(--ink);
    padding: 64px 60px;
    color: var(--surface);
  }

  .flow-title {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .flow-heading {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 48px;
  }

  .flow-diagram {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    align-items: center;
    justify-content: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .flow-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .flow-box {
    background: var(--ink2);
    border: 1.5px solid rgba(255,255,255,0.15);
    padding: 14px 20px;
    text-align: center;
    min-width: 120px;
    position: relative;
    transition: border-color 0.2s;
  }

  .flow-box:hover { border-color: var(--accent); }

  .flow-box-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .flow-box-label {
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  .flow-arrow {
    color: var(--accent);
    font-size: 20px;
    padding: 0 8px;
    line-height: 1;
    margin-top: -20px;
  }

  .flow-split {
    display: flex;
    gap: 16px;
    margin-top: 16px;
  }

  .flow-split-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: #8899cc;
    text-align: center;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  /* ── STAGES ── */
  .stages-container {
    padding: 0 60px 80px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .stages-intro {
    padding: 48px 0 32px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .stage {
    margin-bottom: 64px;
    position: relative;
  }

  .stage::before {
    content: '';
    position: absolute;
    left: -30px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .stage-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 28px;
  }

  .stage-number {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    background: var(--ink);
    color: var(--surface);
    padding: 6px 14px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .stage-title-block h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .stage-title-block p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 680px;
  }

  .stage-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid;
    margin-bottom: 20px;
  }

  .badge-active { border-color: var(--teal); color: var(--teal); background: rgba(10,122,110,0.06); }
  .badge-next { border-color: var(--gold); color: var(--gold); background: rgba(201,134,10,0.06); }
  .badge-later { border-color: var(--muted); color: var(--muted); background: rgba(107,114,128,0.06); }

  .stage-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  @media (max-width: 700px) {
    .stage-grid { grid-template-columns: 1fr; }
    .stages-container { padding: 0 24px 60px; }
    .cover-stats { gap: 24px; }
    .intro { padding: 40px 24px; }
    .flow-section { padding: 48px 24px; }
    .section-header { padding: 36px 24px; }
  }

  .card {
    border: 1.5px solid var(--border);
    padding: 24px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .card-icon { font-size: 18px; }

  .card-header h4 {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .book-item {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  .book-item:last-child { border-bottom: none; padding-bottom: 0; }

  .book-num {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    flex-shrink: 0;
    padding-top: 2px;
  }

  .book-info { flex: 1; }

  .book-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 3px;
  }

  .book-author {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
  }

  .book-edition {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--gold);
    margin-top: 3px;
    letter-spacing: 0.5px;
  }

  .video-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  .video-item:last-child { border-bottom: none; padding-bottom: 0; }

  .video-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .video-name {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
  }

  .video-note {
    font-size: 11px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* Tools card */
  .tools-card {
    border: 1.5px solid var(--border);
    padding: 24px;
    margin-bottom: 20px;
  }

  .tool-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }

  .tool-item:last-child { border-bottom: none; }

  .tool-name {
    font-size: 13px;
    font-weight: 500;
  }

  .tool-type {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    background: var(--ink);
    color: var(--surface);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .tool-free {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    background: var(--teal);
    color: white;
  }

  .tool-paid {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    background: var(--gold);
    color: white;
  }

  /* Outcome card */
  .outcome-card {
    background: var(--ink);
    color: var(--surface);
    padding: 28px;
    margin-top: 20px;
  }

  .outcome-card h4 {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .outcome-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .outcome-list li {
    font-size: 13px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    line-height: 1.5;
  }

  .outcome-list li::before {
    content: '→';
    color: var(--accent);
    flex-shrink: 0;
    font-family: 'Space Mono', monospace;
  }

  /* Stage connector */
  .connector {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    margin: 0 0 32px 0;
  }

  .connector-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .connector-text {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
    white-space: nowrap;
  }

  /* Power Systems section */
  .power-section {
    background: #0a1628;
    color: var(--surface);
    padding: 64px 60px;
    margin-top: 40px;
  }

  /* Master book list */
  .master-list-section {
    padding: 64px 60px;
    background: white;
  }

  .master-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 32px;
    font-size: 13px;
  }

  .master-table th {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 16px;
    background: var(--ink);
    color: var(--surface);
    text-align: left;
    font-weight: 400;
  }

  .master-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .master-table tr:hover td { background: rgba(0,0,0,0.02); }

  .master-table .num-col {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    white-space: nowrap;
  }

  .master-table .stage-col {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
  }

  .master-table .title-col {
    font-weight: 500;
    line-height: 1.4;
  }

  .master-table .author-col {
    font-style: italic;
    color: var(--muted);
    font-size: 12px;
  }

  .master-table .edition-col {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--gold);
    white-space: nowrap;
  }

  /* Footer */
  .footer {
    background: var(--ink);
    color: #4a5568;
    padding: 40px 60px;
    text-align: center;
  }

  .footer p {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    line-height: 2;
  }

  .footer strong { color: var(--accent); }

  /* Print */
  @media print {
    .cover { min-height: auto; padding: 40px; }
    body { font-size: 12px; }
    .stage::before { display: none; }
  }

  /* Accent stripe on stage */
  .stage-stripe {
    height: 3px;
    margin-bottom: 24px;
  }

  .stripe-1 { background: #e8440a; }
  .stripe-2 { background: #c9860a; }
  .stripe-3 { background: #0a7a6e; }
  .stripe-4 { background: #1a3a8f; }
  .stripe-5 { background: #7c3aed; }
  .stripe-6 { background: #be185d; }
  .stripe-7 { background: #065f46; }
  .stripe-8 { background: #92400e; }
  .stripe-9 { background: #1e3a5f; }
  .stripe-10 { background: #4a1942; }

  .full-grid { grid-column: 1 / -1; }

  h2.section-main {
    font-family: 'Syne', sans-serif;
    font-size: clamp(20px, 3vw, 32px);
    font-weight: 800;
    margin-bottom: 8px;
  }

  p.section-desc {
    font-size: 15px;
    color: #8899cc;
    max-width: 600px;
    line-height: 1.6;
  }

  /* ── DEDICATION HERO ── */
  .dedication-hero {
    background: var(--ink);
    color: var(--surface);
    padding: 0;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid var(--accent);
  }

  .dedication-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 39px,
      rgba(255,255,255,0.025) 39px, rgba(255,255,255,0.025) 40px
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 39px,
      rgba(255,255,255,0.025) 39px, rgba(255,255,255,0.025) 40px
    );
    z-index: 0;
  }

  .dedication-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
    padding: 0;
  }

  .ded-top-bar {
    width: 100%;
    background: var(--accent);
    padding: 10px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ded-top-bar span {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: white;
  }

  .ded-photo-wrap {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    position: relative;
  }

  .ded-photo-wrap img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(15%) contrast(1.05);
  }

  .ded-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(10,14,26,0.5) 70%,
      rgba(10,14,26,0.98) 100%
    );
  }

  .ded-text-block {
    width: 100%;
    padding: 0 40px 56px;
    text-align: center;
    margin-top: -120px;
    position: relative;
    z-index: 2;
  }

  .ded-handle {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .ded-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 6vw, 64px);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 16px;
    color: var(--surface);
  }

  .ded-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #8899cc;
    margin-bottom: 32px;
    letter-spacing: 1px;
  }

  .ded-quote {
    max-width: 600px;
    margin: 0 auto 40px;
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    color: #c8d4f0;
    font-style: italic;
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    text-align: left;
  }

  .ded-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 40px;
  }

  .ded-badge {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 16px;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
  }

  .ded-badge.hot {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(232,68,10,0.08);
  }

  .ded-divider {
    width: 60px;
    height: 2px;
    background: var(--accent);
    margin: 0 auto 32px;
  }

  .ded-commitment {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: #4a5568;
    text-transform: uppercase;
  }

  .ded-commitment strong {
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .ded-text-block { padding: 0 24px 48px; margin-top: -80px; }
    .ded-top-bar { padding: 8px 24px; }
  }

</style>
</head>
<body>


<!-- ══════════════════════════════════════ DEDICATION HERO ══════════════════════════════════════ -->
<div class="dedication-hero">
  <div class="dedication-inner">

    <div class="ded-top-bar">
      <span>► Personal Roadmap Document</span>
      <span>VLSI Design & Embedded Systems · 2025 — Onwards</span>
    </div>

    <div class="ded-photo-wrap">
      <img src="data:image/jpeg;base64," alt="Emmanuel Oscar Paul — BlackSILV3" />
      <div class="ded-photo-overlay"></div>
    </div>

    <div class="ded-text-block">
      <div class="ded-handle">@ BlackSILV3</div>
